#!/usr/bin/env bash
# ==============================================================================
# oso-config — terminal (ncurses/TUI) admin for OSOLogic
# ==============================================================================
# The TUI fallback for the web config modules (ui/webmin-oso/*). It talks to the
# same core REST API (/api/v1/*), so a headless box, a serial console or an SSH
# session gets the exact same configuration + monitoring surface as the browser.
#
# Frontend auto-selects dialog → whiptail → plain via lib/oso-ui.sh.
# API base: $OSO_API (default http://127.0.0.1:8080).
#
# (C) Roig Borrell S.L. · Ibercomp S.L. — part of OSOLogic — AGPL-3.0
# ==============================================================================
set -uo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/oso-ui.sh
. "$SCRIPT_DIR/lib/oso-ui.sh"

OSO_API="${OSO_API:-http://127.0.0.1:8080}"
UI_TITLE="OSOLogic Configuration"
UI_BACKTITLE="OSOLogic® — terminal admin · $OSO_API"

# --- REST helpers -------------------------------------------------------------
api_get()  { curl -fsS --max-time 6 "$OSO_API$1" 2>/dev/null; }
api_post() { curl -fsS --max-time 8 -X POST -H 'Content-Type: application/json' -d "$2" "$OSO_API$1" 2>/dev/null; }
# Extract a python expression `d…` from the JSON on stdin.
jexpr() { python3 -c 'import sys,json
try: d=json.load(sys.stdin)
except Exception: sys.exit(1)
try: print(eval(sys.argv[1]))
except Exception: print("")' "$1" 2>/dev/null; }

require_core() {
    if ! api_get /healthz >/dev/null 2>&1; then
        ui_msg "Cannot reach the OSOLogic core at:\n  $OSO_API\n\nStart the core, or set OSO_API to its address."
        return 1
    fi
}

# ==============================================================================
# SSH module (exemplar — mirrors ui/webmin-oso/ssh)
# ==============================================================================
ssh_status_text() {
    local j; j="$(api_get /api/v1/ssh)" || { echo "core offline"; return; }
    local run port; run="$(printf '%s' "$j" | jexpr "'running' if d['status'].get('running') else 'stopped'")"
    port="$(printf '%s' "$j" | jexpr "d['status'].get('settings',{}).get('port','?')")"
    printf 'sshd: %s   ·   port %s' "$run" "$port"
}

ssh_settings_view() {
    local j; j="$(api_get /api/v1/ssh)"
    local body; body="$(printf '%s' "$j" | jexpr "chr(10).join('%-24s %s'%(k,v) for k,v in d['status'].get('settings',{}).items())")"
    ui_msg "Effective sshd directives:\n\n${body:-<none read>}\n\nEdit a directive from the menu; the core writes a drop-in and reloads sshd."
}

ssh_set_directive() {
    ui_menu "Which directive to set?" \
        PermitRootLogin      "root login (recommend: no)" \
        PasswordAuthentication "password auth (recommend: no)" \
        PubkeyAuthentication "public-key auth (recommend: yes)" \
        X11Forwarding        "X11 forwarding (recommend: no)" \
        MaxAuthTries         "max auth tries (recommend: 4)" \
        Port                 "listen port" || return 0
    local key="$UI_VALUE"
    ui_input "New value for $key:" "" || return 0
    local r; r="$(api_post /api/v1/ssh/setting "{\"key\":\"$key\",\"value\":\"$UI_VALUE\"}")"
    local note; note="$(printf '%s' "$r" | jexpr "d.get('note','')")"
    ui_msg "$note"
}

ssh_add_tunnel() {
    ui_menu "Tunnel type:" local "-L local forward" remote "-R remote forward" dynamic "-D SOCKS proxy" || return 0
    local ttype="$UI_VALUE"
    ui_input "Name:" "tunnel" || return 0; local name="$UI_VALUE"
    ui_input "Listen (e.g. 8080):" "" || return 0; local listen="$UI_VALUE"
    local target=""
    if [ "$ttype" != "dynamic" ]; then ui_input "Target host:port:" "" || return 0; target="$UI_VALUE"; fi
    ui_input "SSH host (user@host):" "" || return 0; local host="$UI_VALUE"
    local r; r="$(api_post /api/v1/ssh/tunnel "{\"type\":\"$ttype\",\"name\":\"$name\",\"listen\":\"$listen\",\"target\":\"$target\",\"host\":\"$host\"}")"
    local cmd; cmd="$(printf '%s' "$r" | jexpr "d['tunnel']['cmd']")"
    ui_msg "Tunnel added.\n\nCommand:\n  $cmd\n\nA systemd unit was generated (see the web UI to copy it)."
}

ssh_tunnels_view() {
    local j; j="$(api_get /api/v1/ssh)"
    local body; body="$(printf '%s' "$j" | jexpr "chr(10).join('%-12s %-8s %s -> %s via %s'%(t['name'],t['type'],t['listen'],t.get('target') or '(socks)',t['host']) for t in d.get('tunnels',[])) or '<none>'")"
    ui_msg "Configured tunnels:\n\n$body"
}

ssh_menu() {
    while true; do
        ui_menu "SSH — $(ssh_status_text)" \
            enable   "Enable sshd (on-demand)" \
            disable  "Disable sshd (secure default)" \
            settings "View server directives" \
            harden   "Set a directive" \
            tunnels  "View tunnels" \
            addtun   "Add a tunnel" \
            back     "◀ Back" || return 0
        case "$UI_VALUE" in
            enable)   r="$(api_post /api/v1/ssh/service '{"action":"enable"}')";  ui_msg "$(printf '%s' "$r" | jexpr "d.get('note','done')")" ;;
            disable)  r="$(api_post /api/v1/ssh/service '{"action":"disable"}')"; ui_msg "$(printf '%s' "$r" | jexpr "d.get('note','done')")" ;;
            settings) ssh_settings_view ;;
            harden)   ssh_set_directive ;;
            tunnels)  ssh_tunnels_view ;;
            addtun)   ssh_add_tunnel ;;
            back)     return 0 ;;
        esac
    done
}

# ==============================================================================
# oso-cron module
# ==============================================================================
cron_status_text() {
    local j; j="$(api_get /api/v1/cron)" || { echo "core offline"; return; }
    printf '%s job(s) · %s enabled' \
        "$(printf '%s' "$j" | jexpr "len(d['jobs'])")" \
        "$(printf '%s' "$j" | jexpr "d['enabled_count']")"
}
cron_list_view() {
    local j; j="$(api_get /api/v1/cron)"
    local body; body="$(printf '%s' "$j" | jexpr "chr(10).join('%-14s %-14s %s  [%s]'%(x['name'],x['schedule'],x['command'],'on' if x['enabled'] else 'off') for x in d['jobs']) or '<none>'")"
    ui_msg "Scheduled jobs:\n\n$body"
}
cron_add_job() {
    ui_input "Name:" "job" || return 0; local name="$UI_VALUE"
    ui_menu "Schedule:" "@daily" "every day" "@hourly" "every hour" "@weekly" "every week" \
        "every-5m" "every 5 minutes" "custom" "cron expression" || return 0
    local sched="$UI_VALUE"
    [ "$sched" = custom ] && { ui_input "Cron (min hr dom mon dow):" "* * * * *" || return 0; sched="$UI_VALUE"; }
    ui_input "Command:" "" || return 0; local cmd="$UI_VALUE"
    api_post /api/v1/cron/add "{\"name\":\"$name\",\"schedule\":\"$sched\",\"command\":\"$cmd\"}" >/dev/null
    ui_msg "Job '$name' added  ($sched)."
}
cron_run_job() {
    local j; j="$(api_get /api/v1/cron)"
    local args; args="$(printf '%s' "$j" | jexpr "' '.join('%d \"%s\"'%(x['id'],x['name'].replace(chr(34),chr(39))) for x in d['jobs'])")"
    [ -z "$args" ] && { ui_msg "No jobs defined."; return 0; }
    eval "ui_menu 'Run which job now?' $args" || return 0
    local r; r="$(api_post /api/v1/cron/run "{\"id\":$UI_VALUE}")"
    ui_msg "$(printf '%s' "$r" | jexpr "'status: '+str(d.get('status',d.get('error','?')))+chr(10)+chr(10)+(d.get('output') or '(no output)')")"
}
cron_menu() {
    while true; do
        ui_menu "Scheduler — $(cron_status_text)" \
            list "View jobs" \
            add  "Add a job" \
            run  "Run a job now" \
            back "◀ Back" || return 0
        case "$UI_VALUE" in
            list) cron_list_view ;;
            add)  cron_add_job ;;
            run)  cron_run_job ;;
            back) return 0 ;;
        esac
    done
}

# ==============================================================================
# Date & Time module (timedatectl)
# ==============================================================================
datetime_status_text() {
    local j; j="$(api_get /api/v1/datetime)" || { echo "core offline"; return; }
    printf '%s · NTP %s' \
        "$(printf '%s' "$j" | jexpr "d['status']['timezone']")" \
        "$(printf '%s' "$j" | jexpr "'on' if d['status']['ntp'] else 'off'")"
}
datetime_view() {
    local j; j="$(api_get /api/v1/datetime)"
    ui_msg "$(printf '%s' "$j" | jexpr "'Local:  '+d['status']['local_time']+chr(10)+'UTC:    '+d['status']['utc_time']+chr(10)+'Zone:   '+d['status']['timezone']+chr(10)+'NTP:    '+('on, synced' if d['status']['ntp'] and d['status']['synced'] else ('on, syncing' if d['status']['ntp'] else 'off'))")"
}
datetime_ntp() {
    ui_menu "Network time (NTP):" on "Enable (auto-sync)" off "Disable" || return 0
    local v; [ "$UI_VALUE" = on ] && v=true || v=false
    local r; r="$(api_post /api/v1/datetime/set "{\"action\":\"ntp\",\"enabled\":$v}")"
    ui_msg "$(printf '%s' "$r" | jexpr "d.get('note','done')")"
}
datetime_tz() {
    ui_input "Timezone (Region/City, e.g. Europe/Madrid):" "" || return 0
    local r; r="$(api_post /api/v1/datetime/set "{\"action\":\"timezone\",\"timezone\":\"$UI_VALUE\"}")"
    ui_msg "$(printf '%s' "$r" | jexpr "d.get('note','done')")"
}
datetime_set_time() {
    ui_input "Time (YYYY-MM-DD HH:MM:SS):" "" || return 0
    local r; r="$(api_post /api/v1/datetime/set "{\"action\":\"time\",\"time\":\"$UI_VALUE\"}")"
    ui_msg "$(printf '%s' "$r" | jexpr "d.get('note','done')")"
}
datetime_server() {
    ui_menu "NTP server (serve time to the LAN):" on "Enable" off "Disable" || return 0
    local r
    if [ "$UI_VALUE" = on ]; then
        ui_input "Allowed subnet:" "192.168.0.0/16" || return 0
        r="$(api_post /api/v1/datetime/set "{\"action\":\"ntp_server\",\"enabled\":true,\"subnet\":\"$UI_VALUE\"}")"
    else
        r="$(api_post /api/v1/datetime/set '{"action":"ntp_server","enabled":false}')"
    fi
    ui_msg "$(printf '%s' "$r" | jexpr "d.get('note','done')")"
}
datetime_menu() {
    while true; do
        ui_menu "Date & Time — $(datetime_status_text)" \
            view    "View clock / zone / NTP" \
            ntp     "Toggle network time (NTP client)" \
            server  "NTP server (serve the LAN)" \
            tz      "Set timezone" \
            settime "Set time manually" \
            back    "◀ Back" || return 0
        case "$UI_VALUE" in
            view)    datetime_view ;;
            ntp)     datetime_ntp ;;
            server)  datetime_server ;;
            tz)      datetime_tz ;;
            settime) datetime_set_time ;;
            back)    return 0 ;;
        esac
    done
}

# ==============================================================================
# osowatchdog module
# ==============================================================================
watchdog_status_text() {
    local j; j="$(api_get /api/v1/watchdog)" || { echo "core offline"; return; }
    printf '%s up · %s down' \
        "$(printf '%s' "$j" | jexpr "d['up']")" \
        "$(printf '%s' "$j" | jexpr "d['down']")"
}
watchdog_list_view() {
    local j; j="$(api_get /api/v1/watchdog)"
    ui_msg "$(printf '%s' "$j" | jexpr "chr(10).join('%-12s %-8s %-5s %-24s %s'%(w['name'],w['type'],w['status'],w['target'][:24],'on' if w['enabled'] else 'off') for w in d['watches']) or '<none>'")"
}
watchdog_add_watch() {
    ui_input "Name:" "watch" || return 0; local name="$UI_VALUE"
    ui_menu "Type:" systemd "systemd unit" process "process pattern" tcp "host:port" http "URL" || return 0
    local typ="$UI_VALUE"
    ui_input "Target ($typ):" "" || return 0; local tgt="$UI_VALUE"
    ui_menu "Action:" restart "Restart it" alert "Alert only" none "None" || return 0
    api_post /api/v1/watchdog/add "{\"name\":\"$name\",\"type\":\"$typ\",\"target\":\"$tgt\",\"action\":\"$UI_VALUE\"}" >/dev/null
    ui_msg "Watch '$name' added."
}
watchdog_pick() {
    local j; j="$(api_get /api/v1/watchdog)"
    local args; args="$(printf '%s' "$j" | jexpr "' '.join('%d \"%s [%s]\"'%(w['id'],w['name'],w['status']) for w in d['watches'])")"
    [ -z "$args" ] && { ui_msg "No watches defined."; return 1; }
    eval "ui_menu 'Which watch?' $args"
}
watchdog_check_one() {
    watchdog_pick || return 0
    local r; r="$(api_post /api/v1/watchdog/check "{\"id\":$UI_VALUE}")"
    ui_msg "$(printf '%s' "$r" | jexpr "'status: '+d.get('watch',{}).get('status','?')")"
}
watchdog_restart_one() {
    watchdog_pick || return 0
    local r; r="$(api_post /api/v1/watchdog/restart "{\"id\":$UI_VALUE}")"
    ui_msg "$(printf '%s' "$r" | jexpr "d.get('note', d.get('error','done'))")"
}
watchdog_menu() {
    while true; do
        ui_menu "Watchdog — $(watchdog_status_text)" \
            list    "View watches" \
            add     "Add a watch" \
            check   "Check a watch now" \
            restart "Restart a watch's target" \
            back    "◀ Back" || return 0
        case "$UI_VALUE" in
            list)    watchdog_list_view ;;
            add)     watchdog_add_watch ;;
            check)   watchdog_check_one ;;
            restart) watchdog_restart_one ;;
            back)    return 0 ;;
        esac
    done
}

# ==============================================================================
# Database backend module (osodb source of truth)
# ==============================================================================
database_status_text() {
    local j; j="$(api_get /api/v1/database)" || { echo "core offline"; return; }
    printf 'backend: %s' "$(printf '%s' "$j" | jexpr "d['config']['backend']")"
}
database_view() {
    local j; j="$(api_get /api/v1/database)"
    ui_msg "$(printf '%s' "$j" | jexpr "'Current: '+d['config']['backend']+'  '+d['config']['dsn']+chr(10)+chr(10)+chr(10).join('%-10s %-9s %s'%(b['id'],'[ok]' if b['available'] else '[no drv]',b['desc']) for b in d['backends'])")"
}
database_set_backend() {
    local j; j="$(api_get /api/v1/database)"
    local args; args="$(printf '%s' "$j" | jexpr "' '.join('%s \"%s\"'%(b['id'],b['name']) for b in d['backends'])")"
    eval "ui_menu 'Backend:' $args" || return 0
    local bid="$UI_VALUE"
    local dflt; dflt="$(printf '%s' "$j" | jexpr "next((b['default_dsn'] for b in d['backends'] if b['id']=='$bid'),'')")"
    ui_input "Connection (DSN):" "$dflt" || return 0
    local r; r="$(api_post /api/v1/database/set "{\"backend\":\"$bid\",\"dsn\":\"$UI_VALUE\"}")"
    ui_msg "$(printf '%s' "$r" | jexpr "'saved: '+d.get('config',{}).get('backend','?')+'  '+d.get('config',{}).get('dsn','')")"
}
database_test() {
    local j; j="$(api_get /api/v1/database)"
    local bid; bid="$(printf '%s' "$j" | jexpr "d['config']['backend']")"
    local dsn; dsn="$(printf '%s' "$j" | jexpr "d['config']['dsn']")"
    local r; r="$(api_post /api/v1/database/test "{\"backend\":\"$bid\",\"dsn\":\"$dsn\"}")"
    ui_msg "$(printf '%s' "$r" | jexpr "('OK: ' if d.get('ok') else 'FAIL: ')+d.get('note','')")"
}
database_menu() {
    while true; do
        ui_menu "Database — $(database_status_text)" \
            view "View backends" \
            set  "Choose backend + DSN" \
            test "Test connection" \
            back "◀ Back" || return 0
        case "$UI_VALUE" in
            view) database_view ;;
            set)  database_set_backend ;;
            test) database_test ;;
            back) return 0 ;;
        esac
    done
}

# ==============================================================================
# Backup module (local + remote, verifiable)
# ==============================================================================
backup_status_text() {
    local j; j="$(api_get /api/v1/backup)" || { echo "core offline"; return; }
    printf '%s snapshot(s)' "$(printf '%s' "$j" | jexpr "len(d['snapshots'])")"
}
backup_view() {
    local j; j="$(api_get /api/v1/backup)"
    ui_msg "$(printf '%s' "$j" | jexpr "'Local:     '+d['config']['local_dir']+chr(10)+'Retention: '+str(d['config']['retention'])+chr(10)+'Sources:   '+', '.join(k for k,v in d['config']['sources'].items() if v)+chr(10)+'Remote:    '+(d['config']['remote']['type']+' '+d['config']['remote'].get('target','') if d['config']['remote'].get('enabled') else 'off')+chr(10)+chr(10)+'Snapshots:'+chr(10)+(chr(10).join('  %s  %dKB  %s  [%s]'%(', '.join(s['sources']),s['size_kb'],s['dest'],'verified' if s['verified'] else 'unverified') for s in d['snapshots']) or '  <none>')")"
}
backup_run_now() {
    local r; r="$(api_post /api/v1/backup/run '{"note":"tui"}')"
    ui_msg "$(printf '%s' "$r" | jexpr "d.get('note', d.get('error','done'))")"
}
backup_pick() {
    local j; j="$(api_get /api/v1/backup)"
    local args; args="$(printf '%s' "$j" | jexpr "' '.join('%d \"%s (%dKB)\"'%(s['id'],', '.join(s['sources']),s['size_kb']) for s in d['snapshots'])")"
    [ -z "$args" ] && { ui_msg "No snapshots."; return 1; }
    eval "ui_menu 'Snapshot?' $args"
}
backup_verify() {
    backup_pick || return 0
    local r; r="$(api_post /api/v1/backup/verify "{\"id\":$UI_VALUE}")"
    ui_msg "$(printf '%s' "$r" | jexpr "d.get('note', d.get('error','?'))")"
}
backup_restore() {
    backup_pick || return 0
    ui_yesno "Restore snapshot $UI_VALUE? It overwrites current data." || return 0
    local r; r="$(api_post /api/v1/backup/restore "{\"id\":$UI_VALUE}")"
    ui_msg "$(printf '%s' "$r" | jexpr "d.get('note', d.get('error','?'))")"
}
backup_menu() {
    while true; do
        ui_menu "Backup — $(backup_status_text)" \
            view    "View config + snapshots" \
            run     "Back up now" \
            verify  "Verify a snapshot" \
            restore "Restore a snapshot" \
            back    "◀ Back" || return 0
        case "$UI_VALUE" in
            view)    backup_view ;;
            run)     backup_run_now ;;
            verify)  backup_verify ;;
            restore) backup_restore ;;
            back)    return 0 ;;
        esac
    done
}

# ==============================================================================
# Read-only monitors for other modules (extend with config actions over time)
# ==============================================================================
firewall_view() {
    local j; j="$(api_get /api/v1/firewall)"
    local body; body="$(printf '%s' "$j" | jexpr "chr(10).join(d.get('rules',[])) or '<none>'")"
    ui_msg "Firewall (iptables INPUT):\n\n$body"
}
fail2ban_view() {
    local j; j="$(api_get /api/v1/fail2ban)"
    local body; body="$(printf '%s' "$j" | jexpr "chr(10).join('%-16s banned %s / total %s'%(x['name'],x['banned'],x['total']) for x in d.get('jails',[])) or '<none>'")"
    ui_msg "fail2ban jails:\n\n$body"
}

# ==============================================================================
main_menu() {
    while true; do
        ui_menu "OSOLogic administration — pick a module" \
            ssh      "SSH server, keys & tunnels" \
            cron     "Scheduled tasks (oso-cron)" \
            datetime "Date, time, timezone & NTP" \
            watchdog "Service & process monitor" \
            database "osodb backend & connection" \
            backup   "Backup — local & remote" \
            firewall "Packet filter (view)" \
            fail2ban "Intrusion jails (view)" \
            quit     "Exit" || return 0
        case "$UI_VALUE" in
            ssh)      ssh_menu ;;
            cron)     cron_menu ;;
            datetime) datetime_menu ;;
            watchdog) watchdog_menu ;;
            database) database_menu ;;
            backup)   backup_menu ;;
            firewall) firewall_view ;;
            fail2ban) fail2ban_view ;;
            quit)     return 0 ;;
        esac
    done
}

ui_init
require_core || exit 1
main_menu
clear 2>/dev/null || true
printf 'oso-config — bye.\n'
